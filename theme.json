{
  "$schema": "https://schemas.wp.org/wp/6.2/theme.json",
  "customTemplates": [],
  "settings": {
    "appearanceTools": true,
    "color": {
      "gradients": [],
      "palette": [
        {
          "slug": "theme-0",
          "name": "Forest",
          "color": "#254f43"
        },
        {
          "slug": "theme-1",
          "name": "Moss",
          "color": "#517a63"
        },
        {
          "slug": "theme-2",
          "name": "Slate",
          "color": "#667069"
        },
        {
          "slug": "theme-3",
          "name": "White",
          "color": "#ffffff"
        },
        {
          "slug": "theme-4",
          "name": "Soft Forest",
          "color": "#254f4330"
        },
        {
          "slug": "theme-5",
          "name": "Adventure Gold",
          "color": "#d89a3d"
        },
        {
          "slug": "theme-6",
          "name": "Ink",
          "color": "#202722"
        },
        {
          "slug": "theme-7",
          "name": "Sand",
          "color": "#e4d6b8"
        }
      ]
    },
    "custom": {
      "headings": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--primary)"
        }
      }
    },
    "layout": {
      "contentSize": "1140px",
      "wideSize": "1200px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "blockGap": true,
      "units": [
        "px",
        "em",
        "rem",
        "vh",
        "vw"
      ]
    },
    "typography": {
      "customFontSize": true,
      "fontFamilies": [],
      "fontSizes": [
        {
          "fluid": {
            "min": "0.875rem",
            "max": "1rem"
          },
          "size": "1rem",
          "slug": "small"
        },
        {
          "fluid": {
            "min": "1rem",
            "max": "1.125rem"
          },
          "size": "1.125rem",
          "slug": "medium"
        },
        {
          "fluid": {
            "min": "1.75rem",
            "max": "1.875rem"
          },
          "size": "1.75rem",
          "slug": "large"
        },
        {
          "fluid": false,
          "size": "2.25rem",
          "slug": "x-large"
        },
        {
          "fluid": {
            "min": "4rem",
            "max": "10rem"
          },
          "size": "10rem",
          "slug": "xx-large"
        }
      ]
    }
  },
  "styles": {
    "spacing": {
      "blockGap": 0
    },
    "color": {
      "background": "#f8f5ee",
      "text": "#202722"
    },
    "typography": {
      "fontFamily": "system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
      "lineHeight": "1.6"
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header"
    },
    {
      "area": "footer",
      "name": "footer"
    }
  ],
  "version": 2
}
